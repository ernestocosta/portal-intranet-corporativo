# ─── Banco de Dados ───
DB_NAME=intranet_demo
DB_USER=intranet
DB_PASSWORD=troque-esta-senha
DB_PORT=5432

# ─── Backend ───
API_PORT=3000
SESSION_SECRET=troque-por-uma-chave-secreta-aleatoria

# ─── LDAP / Active Directory ───
# Para teste local, deixe LDAP_ENABLED=false e use as credenciais de demo do README
# Para produção com AD, mude para true e preencha os campos reais do seu domínio
LDAP_ENABLED=false
LDAP_URL=ldap://ldap.exemplo.local:389
LDAP_BASE_DN=DC=exemplo,DC=local
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_DOMAIN=exemplo.local
LDAP_NETBIOS=EXEMPLO
LDAP_NETBIOS_DOMAIN=EXEMPLO

# ─── Frontend (porta exposta ao host) ───
FRONTEND_PORT=8082

# ─── Variáveis injetadas no build do frontend (Vite) ───
# Alteração exige rebuild: docker compose build --no-cache frontend
VITE_INTRANET_URL=http://localhost:8082
VITE_PORTAL_URL=http://localhost:8080
